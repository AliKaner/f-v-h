{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "dependsOn": []
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "type-check": {
      "cache": false
    }
  }
}
